# Set the default behavior: normalize line endings to LF in the repository.
# Git auto-detects text vs binary and converts on checkout per the user's
# core.autocrlf setting (CRLF on Windows, LF on macOS/Linux).
* text=auto eol=lf

# ── Source code (explicit, for clarity) ────────────────────────────────
*.py        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# ── Web assets ─────────────────────────────────────────────────────────
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# ── Binary files (never alter, never diff line-by-line) ────────────────
*.pkl   binary
*.ico   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.zip   binary
*.gz    binary
